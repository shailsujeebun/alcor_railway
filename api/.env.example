DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
REDIS_URL="redis://HOST:6379"
PORT=3000
FRONTEND_URL="https://your-web-service.up.railway.app"
STORAGE_DRIVER="local"
UPLOAD_LOCAL_DIR="/data/uploads"
JWT_SECRET="replace-with-a-long-random-jwt-secret-at-least-32-chars"
UPLOAD_GUEST_TOKEN_SECRET="replace-with-a-different-long-random-secret-at-least-32-chars"
RAILWAY_AUTO_RESEED_ON_VERIFY_FAILURE=true
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
MAIL_FROM="noreply@example.com"
MAIL_FROM_NAME="ALCOR"

# Only required when STORAGE_DRIVER=s3
# S3_ENDPOINT="https://your-object-storage-endpoint"
# S3_REGION="auto"
# S3_BUCKET="marketplace"
# S3_ACCESS_KEY_ID="replace-with-a-non-default-storage-credential"
# S3_SECRET_ACCESS_KEY="replace-with-a-long-random-storage-secret"
# S3_PUBLIC_URL="https://your-public-bucket-url"
# S3_PUBLIC_READ_ASSETS=false
